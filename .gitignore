# ==========================================
# Root Gitignore for DianSoapFrontend Workspace
# ==========================================

# Dependency directories (Global)
node_modules/
jspm_packages/
web_modules/

# Angular / Build output
dist/
tmp/
out-tsc/
bazel-out/
/coverage/
/e2e/test-output/
.angular/
*.tsbuildinfo


# Environment and Secret files (CRITICAL: Do not upload secrets)
.env
.env.local
.env.*.local
*.env
.secret
*.secret

# IDEs and Editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

